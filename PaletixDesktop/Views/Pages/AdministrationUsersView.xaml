<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PaletixDesktop.Views.Pages.AdministrationUsersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="AdministrationUsersView_Loaded">

    <UserControl.Resources>
        <Style x:Key="AdminCellBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="AdminCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Padding="28,24,28,28" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="430" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Usuaris i rols" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBox
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    PlaceholderText="Cercar id, nom, DNI, email, rol, carrec o sync"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <SelectorBar Grid.Row="1" x:Name="AdminSelectorBar" SelectionChanged="AdminSelectorBar_SelectionChanged">
                <SelectorBarItem x:Name="UsersSelectorItem" Text="Usuaris" IsSelected="True" />
                <SelectorBarItem x:Name="RolesSelectorItem" Text="Rols" />
                <SelectorBarItem x:Name="JobTitlesSelectorItem" Text="Carrecs" />
            </SelectorBar>

            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="14" Style="{StaticResource ShellCardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Usuaris" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding TotalUsers}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="14" Style="{StaticResource ShellCardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Rols" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding TotalRoles}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="14" Style="{StaticResource ShellCardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Pendents" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ActivePendingCount}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Administracio" />
                        <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Gestio de treballadors, rols i carrecs." />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressRing Width="22" Height="22" IsActive="True" Background="LightGray" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Carregant..." />
                    </StackPanel>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SelectedCountText}" />
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource ShellCardBorderStyle}" Visibility="{Binding IsUsersTab, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ListView x:Name="UsersList" Background="Transparent" ItemsSource="{Binding FilteredUsers}" SelectionChanged="UsersSelectionChanged" SelectionMode="Multiple">
                            <ListView.Header>
                                <Grid MinWidth="1560" MinHeight="46" Background="{StaticResource AppSurfaceAltBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="230" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="230" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource AdminCellBorderStyle}"><CheckBox x:Name="SelectVisibleUsersCheckBox" Style="{StaticResource AdminCheckBoxStyle}" Click="UsersHeaderCheckBox_Click" /></Border>
                                    <Border Grid.Column="1" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="ID" /></Border>
                                    <Border Grid.Column="2" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Nom complet" /></Border>
                                    <Border Grid.Column="3" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="DNI/NIE" /></Border>
                                    <Border Grid.Column="4" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Correu electronic" /></Border>
                                    <Border Grid.Column="5" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Telefon" /></Border>
                                    <Border Grid.Column="6" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Rol" /></Border>
                                    <Border Grid.Column="7" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Carrec" /></Border>
                                    <Border Grid.Column="8" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Contractacio" /></Border>
                                    <Border Grid.Column="9" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Nivell" /></Border>
                                    <Border Grid.Column="10" Padding="12,10"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Sync" /></Border>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinWidth="1560" MinHeight="64" Opacity="{Binding IsPending, Converter={StaticResource BoolToOpacityConverter}, ConverterParameter=0.72}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="62" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource AdminCellBorderStyle}"><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource AdminCheckBoxStyle}" Tag="{Binding}" Click="UserCheckBox_Click" /></Border>
                                        <Border Grid.Column="1" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Id}" /></Border>
                                        <Border Grid.Column="2" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding NomComplet}" TextTrimming="CharacterEllipsis" /></Border>
                                        <Border Grid.Column="3" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding Dni}" /></Border>
                                        <Border Grid.Column="4" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding Email}" TextTrimming="CharacterEllipsis" /></Border>
                                        <Border Grid.Column="5" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding Telefon}" /></Border>
                                        <Border Grid.Column="6" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding RolText}" TextTrimming="CharacterEllipsis" /></Border>
                                        <Border Grid.Column="7" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding CarrecText}" TextTrimming="CharacterEllipsis" /></Border>
                                        <Border Grid.Column="8" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding DataContractacioText}" /></Border>
                                        <Border Grid.Column="9" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding NivellText}" /></Border>
                                        <Border Grid.Column="10" Padding="12,10"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SyncStateText}" TextTrimming="CharacterEllipsis" /></Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ShellCardBorderStyle}" Visibility="{Binding IsRolesTab, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ListView x:Name="RolesList" Background="Transparent" ItemsSource="{Binding FilteredRoles}" SelectionChanged="RolesSelectionChanged" SelectionMode="Multiple">
                            <ListView.Header>
                                <Grid MinWidth="900" MinHeight="46" Background="{StaticResource AppSurfaceAltBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource AdminCellBorderStyle}"><CheckBox x:Name="SelectVisibleRolesCheckBox" Style="{StaticResource AdminCheckBoxStyle}" Click="RolesHeaderCheckBox_Click" /></Border>
                                    <Border Grid.Column="1" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="ID" /></Border>
                                    <Border Grid.Column="2" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Nom del rol" /></Border>
                                    <Border Grid.Column="3" Padding="12,10"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Sync" /></Border>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinWidth="900" MinHeight="58" Opacity="{Binding IsPending, Converter={StaticResource BoolToOpacityConverter}, ConverterParameter=0.72}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="62" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource AdminCellBorderStyle}"><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource AdminCheckBoxStyle}" Tag="{Binding}" Click="RoleCheckBox_Click" /></Border>
                                        <Border Grid.Column="1" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Id}" /></Border>
                                        <Border Grid.Column="2" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Nom}" /></Border>
                                        <Border Grid.Column="3" Padding="12,10"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SyncStateText}" /></Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ShellCardBorderStyle}" Visibility="{Binding IsJobTitlesTab, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ListView x:Name="JobTitlesList" Background="Transparent" ItemsSource="{Binding FilteredJobTitles}" SelectionChanged="JobTitlesSelectionChanged" SelectionMode="Multiple">
                            <ListView.Header>
                                <Grid MinWidth="900" MinHeight="46" Background="{StaticResource AppSurfaceAltBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource AdminCellBorderStyle}"><CheckBox x:Name="SelectVisibleJobTitlesCheckBox" Style="{StaticResource AdminCheckBoxStyle}" Click="JobTitlesHeaderCheckBox_Click" /></Border>
                                    <Border Grid.Column="1" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="ID" /></Border>
                                    <Border Grid.Column="2" Style="{StaticResource AdminCellBorderStyle}"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Nom del carrec" /></Border>
                                    <Border Grid.Column="3" Padding="12,10"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Sync" /></Border>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinWidth="900" MinHeight="58" Opacity="{Binding IsPending, Converter={StaticResource BoolToOpacityConverter}, ConverterParameter=0.72}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="62" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource AdminCellBorderStyle}"><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource AdminCheckBoxStyle}" Tag="{Binding}" Click="JobTitleCheckBox_Click" /></Border>
                                        <Border Grid.Column="1" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Id}" /></Border>
                                        <Border Grid.Column="2" Style="{StaticResource AdminCellBorderStyle}"><TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Nom}" /></Border>
                                        <Border Grid.Column="3" Padding="12,10"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SyncStateText}" /></Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border Background="#4D000000" IsHitTestVisible="True" Visibility="{Binding IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Border
            Width="620"
            Padding="24"
            HorizontalAlignment="Right"
            Background="{StaticResource AppSurfaceBrush}"
            BorderBrush="{StaticResource AppStrokeBrush}"
            BorderThickness="1,0,0,0"
            Visibility="{Binding IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding PanelTitle}" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding PanelSubtitle}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <InfoBar
                            IsClosable="False"
                            IsIconVisible="True"
                            IsOpen="{Binding HasValidationErrors}"
                            Message="{Binding ValidationMessage}"
                            Severity="Error"
                            Title="Revisa el formulari" />

                        <StackPanel Spacing="12" Visibility="{Binding IsUsersTab, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox Header="Nom" PlaceholderText="Nom del treballador" Text="{Binding UserDraft.Nom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1" Header="Cognoms" PlaceholderText="Cognoms" Text="{Binding UserDraft.Cognoms, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1" Header="DNI/NIE" PlaceholderText="12345678Z" Text="{Binding UserDraft.Dni, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1" Grid.Column="1" Header="Telefon" PlaceholderText="+34 600 000 000" Text="{Binding UserDraft.Telefon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="2" Grid.ColumnSpan="2" Header="Correu electronic" PlaceholderText="usuari@empresa.com" Text="{Binding UserDraft.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <DatePicker Grid.Row="3" Header="Naixement" Date="{Binding BirthDate, Mode=TwoWay}" />
                                <DatePicker Grid.Row="3" Grid.Column="1" Header="Contractacio" Date="{Binding ContractDate, Mode=TwoWay}" />
                                <ComboBox Grid.Row="4" Header="Rol" DisplayMemberPath="DisplayText" ItemsSource="{Binding RoleOptions}" PlaceholderText="Selecciona rol" SelectedValue="{Binding UserDraft.IdRol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Id" />
                                <ComboBox Grid.Row="4" Grid.Column="1" Header="Carrec" DisplayMemberPath="DisplayText" ItemsSource="{Binding JobTitleOptions}" PlaceholderText="Selecciona carrec" SelectedValue="{Binding UserDraft.IdCarrec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Id" />
                            </Grid>

                            <TextBox Header="Contrasenya" PlaceholderText="Minim 8 caracters. En editar, deixa-ho buit per conservar-la." Text="{Binding UserDraft.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <NumberBox Header="Salari" Minimum="0" SpinButtonPlacementMode="Inline" SmallChange="100" LargeChange="1000" Value="{Binding DraftSalariValue, Mode=TwoWay}" />
                                <NumberBox Grid.Column="1" Header="Torn" Minimum="0" SpinButtonPlacementMode="Inline" SmallChange="1" LargeChange="1" Value="{Binding DraftTornValue, Mode=TwoWay}" />
                                <NumberBox Grid.Column="2" Header="Experiencia" Minimum="0" SpinButtonPlacementMode="Inline" SmallChange="1" LargeChange="5" Value="{Binding DraftAnysExperienciaValue, Mode=TwoWay}" />
                                <NumberBox Grid.Row="1" Header="Saldo punts" Minimum="0" SpinButtonPlacementMode="Inline" SmallChange="10" LargeChange="100" Value="{Binding DraftSaldoPuntsValue, Mode=TwoWay}" />
                                <NumberBox Grid.Row="1" Grid.Column="1" Header="Nivell" Minimum="1" SpinButtonPlacementMode="Inline" SmallChange="1" LargeChange="5" Value="{Binding DraftNivellValue, Mode=TwoWay}" />
                            </Grid>

                            <TextBox Header="N. Seguretat Social" PlaceholderText="Opcional" Text="{Binding UserDraft.NumSeguretatSocial, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="Compte bancari" PlaceholderText="Opcional" Text="{Binding UserDraft.NumCompteBancari, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Spacing="12" Visibility="{Binding IsRolesTab, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBox Header="Nom del rol" PlaceholderText="Administrador, Preparador, Comercial..." Text="{Binding SimpleDraft.Nom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Spacing="12" Visibility="{Binding IsJobTitlesTab, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBox Header="Nom del carrec" PlaceholderText="Cap de magatzem, Operari, Xofer..." Text="{Binding SimpleDraft.Nom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                    <Button MinWidth="110" Content="Cancelar" Click="CancelButton_Click" />
                    <Button MinWidth="110" Background="{StaticResource AppAccentBrush}" Foreground="White" Content="Guardar" Click="SaveButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
