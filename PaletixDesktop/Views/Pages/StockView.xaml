<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PaletixDesktop.Views.Pages.StockView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="StockView_Loaded">

    <UserControl.Resources>
        <Style x:Key="WarehouseCellBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
        <Style x:Key="WarehouseTableItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="WarehouseSelectionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="StockTableRowTemplate">
            <Grid MinWidth="1180" MinHeight="70" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,0,1" Opacity="{Binding IsPending, Converter={StaticResource BoolToOpacityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource WarehouseCellBorderStyle}">
                    <CheckBox Click="RecordCheckBox_Click" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource WarehouseSelectionCheckBoxStyle}" Tag="{Binding}" />
                </Border>
                <Border Grid.Column="1" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding IdText}" /></Border>
                <Border Grid.Column="2" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ProducteText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="3" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding UbicacioText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="4" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding LotText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="5" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding TotalsEnStock}" /></Border>
                <Border Grid.Column="6" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ReservatsPerComandes}" /></Border>
                <Border Grid.Column="7" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding DisponiblesText}" /></Border>
                <Border Grid.Column="8" Style="{StaticResource WarehouseCellBorderStyle}">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding SyncStateText}" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SyncMessage}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="9" Padding="10">
                    <Button Width="34" Height="34" Padding="0" Click="EditButton_Click" Tag="{Binding}">
                        <FontIcon FontSize="14" Glyph="&#xE7C9;" />
                    </Button>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="StockGridItemTemplate">
            <Border Width="300" MinHeight="190" Margin="0,0,12,12" Opacity="{Binding IsPending, Converter={StaticResource BoolToOpacityConverter}}" Style="{StaticResource ShellCardBorderStyle}">
                <StackPanel Padding="14" Spacing="8">
                    <Grid>
                        <TextBlock FontSize="12" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding IdText}" />
                        <CheckBox HorizontalAlignment="Right" Click="RecordCheckBox_Click" IsChecked="{Binding IsSelected, Mode=TwoWay}" Tag="{Binding}" />
                    </Grid>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ProducteText}" TextWrapping="WrapWholeWords" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding UbicacioText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding LotText}" TextTrimming="CharacterEllipsis" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding TotalsEnStock}" />
                        <TextBlock Grid.Column="1" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SyncStateText}" />
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LocationPickerCellTemplate">
            <Button Width="116" Height="64" Margin="0,0,8,8" Padding="8" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Click="LocationPickerCell_Click" Tag="{Binding}">
                <StackPanel Spacing="2">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding CodeText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="11" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding StateText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="11" Foreground="{StaticResource AppSecondaryTextBrush}">
                        <Run Text="F" /><Run Text="{Binding Fila}" /><Run Text=" · C" /><Run Text="{Binding Columna}" />
                    </TextBlock>
                </StackPanel>
            </Button>
        </DataTemplate>
        <DataTemplate x:Key="LocationPickerRowTemplate">
            <Grid ColumnSpacing="10" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding Title}" />
                <ItemsControl Grid.Column="1" ItemTemplate="{StaticResource LocationPickerCellTemplate}" ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="LocationPickerBlockTemplate">
            <Border MinWidth="380" Margin="0,0,14,14" Padding="14" Style="{StaticResource ShellCardBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Title}" />
                    <ItemsControl ItemTemplate="{StaticResource LocationPickerRowTemplate}" ItemsSource="{Binding Rows}" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="LocationPickerZoneTemplate">
            <StackPanel Spacing="10" Margin="0,0,0,18">
                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Title}" />
                <ItemsControl ItemTemplate="{StaticResource LocationPickerBlockTemplate}" ItemsSource="{Binding Blocks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="HistoryRowTemplate">
            <Grid MinWidth="980" MinHeight="58" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Tipus}" /></Border>
                <Border Grid.Column="1" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ProducteText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="2" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding Quantitat}" /></Border>
                <Border Grid.Column="3" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding OrigenText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="4" Style="{StaticResource WarehouseCellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding DestiText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="5" Padding="12,10"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding DataText}" /></Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Padding="24,18,24,24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Stock" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Existencies operatives: entrades, moviments, ajustos i reserves." TextWrapping="Wrap" />
                </StackPanel>
                <TextBox Grid.Column="1" VerticalAlignment="Bottom" PlaceholderText="Cercar id, producte, ubicacio o lot" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Total" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding TotalCount}" /></StackPanel></Border>
                <Border Grid.Column="1" Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Filtrats" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding FilteredCount}" /></StackPanel></Border>
                <Border Grid.Column="2" Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Reservats" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ReservedCount}" /></StackPanel></Border>
                <Border Grid.Column="3" Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Baix disponible" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding LowAvailableCount}" /></StackPanel></Border>
            </Grid>

            <Grid Grid.Row="2" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Existencies" />
                        <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SelectedCountText}" />
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource ShellCardBorderStyle}">
                    <Grid>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Visibility="{Binding IsTableView, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid MinWidth="1180">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid MinWidth="1180" Background="{StaticResource AppSurfaceAltBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" /><ColumnDefinition Width="70" /><ColumnDefinition Width="240" /><ColumnDefinition Width="220" /><ColumnDefinition Width="170" /><ColumnDefinition Width="130" /><ColumnDefinition Width="150" /><ColumnDefinition Width="130" /><ColumnDefinition Width="160" /><ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><CheckBox x:Name="SelectVisibleCheckBox" Click="HeaderCheckBox_Click" IsThreeState="True" Style="{StaticResource WarehouseSelectionCheckBoxStyle}" /></Border>
                                    <Border Grid.Column="1" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="ID" /></Border>
                                    <Border Grid.Column="2" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Producte" /></Border>
                                    <Border Grid.Column="3" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Ubicacio" /></Border>
                                    <Border Grid.Column="4" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Lot" /></Border>
                                    <Border Grid.Column="5" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Total" /></Border>
                                    <Border Grid.Column="6" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Reservat" /></Border>
                                    <Border Grid.Column="7" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Disponible" /></Border>
                                    <Border Grid.Column="8" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Sincronitzacio" /></Border>
                                    <Border Grid.Column="9" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,0,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="" /></Border>
                                </Grid>
                                <ListView x:Name="RecordsTable" Grid.Row="1" MinWidth="1180" Background="Transparent" ContextRequested="Records_ContextRequested" IsMultiSelectCheckBoxEnabled="False" ItemContainerStyle="{StaticResource WarehouseTableItemStyle}" ItemTemplate="{StaticResource StockTableRowTemplate}" ItemsSource="{Binding FilteredRecords}" SelectionChanged="RecordsSelectionChanged" SelectionMode="Multiple" />
                            </Grid>
                        </ScrollViewer>
                        <GridView x:Name="RecordsGrid" Padding="14" Background="Transparent" ContextRequested="Records_ContextRequested" IsMultiSelectCheckBoxEnabled="False" ItemTemplate="{StaticResource StockGridItemTemplate}" ItemsSource="{Binding FilteredRecords}" SelectionChanged="RecordsSelectionChanged" SelectionMode="Multiple" Visibility="{Binding IsGridView, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Column="0" Background="#4D000000" IsHitTestVisible="True" Visibility="{Binding IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Border Grid.Column="1" Width="520" Padding="24" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1,0,0,0" Visibility="{Binding IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Spacing="4"><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding PanelTitle}" /><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding PanelSubtitle}" /></StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Visibility="{Binding IsEditingMultiple, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Width="34" Height="34" Padding="0" Click="PreviousEditButton_Click"><FontIcon Glyph="&#xE72B;" /></Button>
                        <Button Width="34" Height="34" Padding="0" Click="NextEditButton_Click"><FontIcon Glyph="&#xE72A;" /></Button>
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="12">
                        <Border Padding="12" Background="{StaticResource AppDangerBrush}" CornerRadius="6" Visibility="{Binding HasValidationErrors, Converter={StaticResource BoolToVisibilityConverter}}"><TextBlock Foreground="White" Text="{Binding ValidationMessage}" TextWrapping="WrapWholeWords" /></Border>
                        <ComboBox Header="Producte" DisplayMemberPath="DisplayText" ItemsSource="{Binding ProductOptions}" PlaceholderText="Selecciona producte" SelectedValue="{Binding DraftIdProducte, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Ubicacio" DisplayMemberPath="DisplayText" ItemsSource="{Binding LocationOptions}" PlaceholderText="Selecciona ubicacio" SelectedValue="{Binding DraftIdUbicacio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                            <Button Grid.Column="1" Width="96" VerticalAlignment="Bottom" Click="OpenLocationPickerButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE707;" />
                                    <TextBlock Text="Mapa" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock FontSize="12" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SelectedLocationText}" TextTrimming="CharacterEllipsis" />
                        <ComboBox Header="Lot" DisplayMemberPath="DisplayText" ItemsSource="{Binding LotOptions}" PlaceholderText="Sense lot" SelectedValue="{Binding DraftIdLot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                        <NumberBox Header="Total en stock" Minimum="0" PlaceholderText="0" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" Value="{Binding DraftTotalsEnStockValue, Mode=TwoWay}" />
                        <NumberBox Header="Reservat per comandes" Minimum="0" PlaceholderText="0" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" Value="{Binding DraftReservatsPerComandesValue, Mode=TwoWay}" />
                    </StackPanel>
                </ScrollViewer>
                <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                    <Button Click="CancelPanelButton_Click" Content="Cancelar" />
                    <Button Background="{StaticResource AppAccentBrush}" Click="SavePanelButton_Click" Content="Guardar" Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="0" Background="#4D000000" IsHitTestVisible="True" Visibility="{Binding IsOperationPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Border Grid.Column="1" Width="540" Padding="24" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1,0,0,0" Visibility="{Binding IsOperationPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding OperationPanelTitle}" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding OperationSelectedStockText}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="12">
                        <Border Padding="12" Background="{StaticResource AppDangerBrush}" CornerRadius="6" Visibility="{Binding HasValidationErrors, Converter={StaticResource BoolToVisibilityConverter}}"><TextBlock Foreground="White" Text="{Binding ValidationMessage}" TextWrapping="WrapWholeWords" /></Border>

                        <StackPanel Spacing="12" Visibility="{Binding IsEntradaMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ComboBox Header="Producte" DisplayMemberPath="DisplayText" ItemsSource="{Binding ProductOptions}" PlaceholderText="Selecciona producte" SelectedValue="{Binding OperationIdProducte, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <ComboBox Header="Ubicacio" DisplayMemberPath="DisplayText" ItemsSource="{Binding LocationOptions}" PlaceholderText="Selecciona ubicacio" SelectedValue="{Binding OperationIdUbicacio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                                <Button Grid.Column="1" Width="96" VerticalAlignment="Bottom" Click="OpenLocationPickerButton_Click"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE707;" /><TextBlock Text="Mapa" /></StackPanel></Button>
                            </Grid>
                            <ComboBox Header="Lot" DisplayMemberPath="DisplayText" ItemsSource="{Binding LotOptions}" PlaceholderText="Sense lot" SelectedValue="{Binding OperationIdLot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                        </StackPanel>

                        <StackPanel Spacing="12" Visibility="{Binding IsMovimentMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ComboBox Header="Producte" DisplayMemberPath="DisplayText" ItemsSource="{Binding ProductOptions}" PlaceholderText="Selecciona producte" SelectedValue="{Binding OperationIdProducte, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                            <ComboBox Header="Ubicacio origen" DisplayMemberPath="DisplayText" ItemsSource="{Binding LocationOptions}" PlaceholderText="Origen" SelectedValue="{Binding OperationIdUbicacioOrigen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <ComboBox Header="Ubicacio desti" DisplayMemberPath="DisplayText" ItemsSource="{Binding LocationOptions}" PlaceholderText="Desti" SelectedValue="{Binding OperationIdUbicacioDesti, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                                <Button Grid.Column="1" Width="96" VerticalAlignment="Bottom" Click="OpenLocationPickerButton_Click"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE707;" /><TextBlock Text="Mapa" /></StackPanel></Button>
                            </Grid>
                            <ComboBox Header="Lot" DisplayMemberPath="DisplayText" ItemsSource="{Binding LotOptions}" PlaceholderText="Sense lot" SelectedValue="{Binding OperationIdLot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                        </StackPanel>

                        <NumberBox Header="Quantitat" Minimum="1" PlaceholderText="1" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" Value="{Binding OperationQuantitatValue, Mode=TwoWay}" Visibility="{Binding IsQuantityOperationMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <NumberBox Header="Nou total fisic" Minimum="0" PlaceholderText="0" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" Value="{Binding OperationNouTotalValue, Mode=TwoWay}" Visibility="{Binding IsAjustMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBox Header="Motiu" PlaceholderText="Inventari inicial, trasllat, recompte..." Text="{Binding OperationMotiu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
                <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                    <Button Click="CancelOperationButton_Click" Content="Cancelar" />
                    <Button Background="{StaticResource AppAccentBrush}" Click="SaveOperationButton_Click" Content="Aplicar" Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.ColumnSpan="2" Background="#99000000" IsHitTestVisible="True" Visibility="{Binding IsLocationPickerOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Border Grid.ColumnSpan="2" Width="1180" MaxWidth="1180" Height="760" MaxHeight="760" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1" CornerRadius="8" Visibility="{Binding IsLocationPickerOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Seleccionar ubicacio" />
                        <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Tria una posicio des del mapa visual o tanca per continuar amb el desplegable." />
                    </StackPanel>
                    <Button Grid.Column="1" Width="36" Height="36" Padding="0" Click="CancelLocationPickerButton_Click">
                        <FontIcon Glyph="&#xE711;" />
                    </Button>
                </Grid>
                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SelectedLocationText}" TextTrimming="CharacterEllipsis" />
                    <TextBox Grid.Column="1" PlaceholderText="Cercar id, codi, zona o passadis" Text="{Binding LocationPickerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Border Grid.Row="2" Style="{StaticResource ShellCardBorderStyle}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <StackPanel MinWidth="1040" Padding="16">
                            <ItemsControl ItemTemplate="{StaticResource LocationPickerZoneTemplate}" ItemsSource="{Binding LocationPickerZones}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <StackPanel Grid.Row="3" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                    <Button Click="CancelLocationPickerButton_Click" Content="Tancar" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.ColumnSpan="2" Background="#99000000" IsHitTestVisible="True" Visibility="{Binding IsHistoryOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Border Grid.ColumnSpan="2" Width="1120" Height="700" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1" CornerRadius="8" Visibility="{Binding IsHistoryOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Historial de stock" />
                        <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Moviments operatius persistents carregats de l'API." />
                    </StackPanel>
                    <Button Grid.Column="1" Width="36" Height="36" Padding="0" Click="CloseHistoryButton_Click"><FontIcon Glyph="&#xE711;" /></Button>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource ShellCardBorderStyle}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid MinWidth="980">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid Background="{StaticResource AppSurfaceAltBrush}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="210" /><ColumnDefinition Width="90" /><ColumnDefinition Width="190" /><ColumnDefinition Width="190" /><ColumnDefinition Width="180" /></Grid.ColumnDefinitions>
                                <Border Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Tipus" /></Border>
                                <Border Grid.Column="1" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Producte" /></Border>
                                <Border Grid.Column="2" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Quantitat" /></Border>
                                <Border Grid.Column="3" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Origen" /></Border>
                                <Border Grid.Column="4" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Desti" /></Border>
                                <Border Grid.Column="5" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,0,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Data" /></Border>
                            </Grid>
                            <ListView Grid.Row="1" Background="Transparent" ItemTemplate="{StaticResource HistoryRowTemplate}" ItemsSource="{Binding HistoryRecords}" />
                        </Grid>
                    </ScrollViewer>
                </Border>
                <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10"><Button Click="CloseHistoryButton_Click" Content="Tancar" /></StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
