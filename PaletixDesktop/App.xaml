<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PaletixDesktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PaletixDesktop.Converters"
    xmlns:local="using:PaletixDesktop"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BooleanToOpacityConverter x:Key="BoolToOpacityConverter" />

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#151B24" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#202631" />
            <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#252C38" />
            <SolidColorBrush x:Key="AppStrokeBrush" Color="#465060" />
            <SolidColorBrush x:Key="AppPrimaryTextBrush" Color="#F6F8FA" />
            <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#B3BAC4" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#147260" />
            <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#243E39" />
            <SolidColorBrush x:Key="AppWarningBrush" Color="#A96F16" />
            <SolidColorBrush x:Key="AppDangerBrush" Color="#A3343A" />

            <Style x:Key="ShellCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="ShellTopTabItemStyle" TargetType="ListViewItem">
                <Setter Property="MinWidth" Value="112" />
                <Setter Property="Margin" Value="3,0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="ShellSectionItemStyle" TargetType="ListViewItem">
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
