<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PaletixDesktop.Views.Pages.SupplierLotsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="SupplierLotsView_Loaded">

    <UserControl.Resources>
        <Style x:Key="CellBorderStyle" TargetType="Border"><Setter Property="Padding" Value="12,10" /><Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" /><Setter Property="BorderThickness" Value="0,0,1,0" /></Style>
        <Style x:Key="TableItemStyle" TargetType="ListViewItem"><Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="0" /><Setter Property="MinHeight" Value="70" /><Setter Property="HorizontalContentAlignment" Value="Stretch" /></Style>
        <Style x:Key="SelectionCheckBoxStyle" TargetType="CheckBox"><Setter Property="Width" Value="30" /><Setter Property="Height" Value="30" /><Setter Property="MinWidth" Value="30" /><Setter Property="Padding" Value="0" /><Setter Property="HorizontalAlignment" Value="Center" /><Setter Property="VerticalAlignment" Value="Center" /></Style>
        <DataTemplate x:Key="TableRowTemplate">
            <Grid MinWidth="1230" MinHeight="70" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,0,1" Opacity="{Binding IsPending, Converter={StaticResource BoolToOpacityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" /><ColumnDefinition Width="70" /><ColumnDefinition Width="220" /><ColumnDefinition Width="240" /><ColumnDefinition Width="130" /><ColumnDefinition Width="140" /><ColumnDefinition Width="140" /><ColumnDefinition Width="150" /><ColumnDefinition Width="180" /><ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource CellBorderStyle}"><CheckBox Click="RecordCheckBox_Click" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource SelectionCheckBoxStyle}" Tag="{Binding}" /></Border>
                <Border Grid.Column="1" Style="{StaticResource CellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding IdText}" /></Border>
                <Border Grid.Column="2" Style="{StaticResource CellBorderStyle}"><TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ProveidorText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="3" Style="{StaticResource CellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ProducteText}" TextTrimming="CharacterEllipsis" /></Border>
                <Border Grid.Column="4" Style="{StaticResource CellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding QuantitatRebuda}" /></Border>
                <Border Grid.Column="5" Style="{StaticResource CellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding DataDemanatText}" /></Border>
                <Border Grid.Column="6" Style="{StaticResource CellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding DataRebutText}" /></Border>
                <Border Grid.Column="7" Style="{StaticResource CellBorderStyle}"><TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding DataCaducitatText}" /></Border>
                <Border Grid.Column="8" Style="{StaticResource CellBorderStyle}"><StackPanel VerticalAlignment="Center" Spacing="2"><TextBlock Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding SyncStateText}" /><TextBlock FontSize="12" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SyncMessage}" TextTrimming="CharacterEllipsis" /></StackPanel></Border>
                <Border Grid.Column="9" Padding="10"><Button Width="34" Height="34" Padding="0" Click="EditButton_Click" Tag="{Binding}"><FontIcon FontSize="14" Glyph="&#xE70F;" /></Button></Border>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="GridItemTemplate">
            <Border Width="310" MinHeight="195" Margin="0,0,12,12" Opacity="{Binding IsPending, Converter={StaticResource BoolToOpacityConverter}}" Style="{StaticResource ShellCardBorderStyle}">
                <StackPanel Padding="14" Spacing="8">
                    <Grid><TextBlock FontSize="12" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding IdText}" /><CheckBox HorizontalAlignment="Right" Click="RecordCheckBox_Click" IsChecked="{Binding IsSelected, Mode=TwoWay}" Tag="{Binding}" /></Grid>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ProducteText}" TextWrapping="WrapWholeWords" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding ProveidorText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding QuantitatRebuda}" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding DataCaducitatText}" />
                    <TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SyncStateText}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
        <Grid Padding="24,18,24,24" RowSpacing="14">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="420" /></Grid.ColumnDefinitions>
                <StackPanel Spacing="4"><TextBlock FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Lots" /><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Entrades de proveidor, quantitat rebuda i caducitats." /></StackPanel>
                <TextBox Grid.Column="1" VerticalAlignment="Bottom" PlaceholderText="Cercar id, proveidor, producte o caducitat" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Total" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding TotalCount}" /></StackPanel></Border>
                <Border Grid.Column="1" Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Filtrats" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding FilteredCount}" /></StackPanel></Border>
                <Border Grid.Column="2" Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Unitats rebudes" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding TotalQuantity}" /></StackPanel></Border>
                <Border Grid.Column="3" Padding="14" Style="{StaticResource ShellCardBorderStyle}"><StackPanel Spacing="4"><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="Caduca aviat" /><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding ExpiringCount}" /></StackPanel></Border>
            </Grid>
            <Grid Grid.Row="2" RowSpacing="10">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Spacing="2"><TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="Lots rebuts" /><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" /></StackPanel><TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding SelectedCountText}" /></Grid>
                <Border Grid.Row="1" Style="{StaticResource ShellCardBorderStyle}">
                    <Grid>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Visibility="{Binding IsTableView, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid MinWidth="1230">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid MinWidth="1230" Background="{StaticResource AppSurfaceAltBrush}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="70" /><ColumnDefinition Width="220" /><ColumnDefinition Width="240" /><ColumnDefinition Width="130" /><ColumnDefinition Width="140" /><ColumnDefinition Width="140" /><ColumnDefinition Width="150" /><ColumnDefinition Width="180" /><ColumnDefinition Width="56" /></Grid.ColumnDefinitions>
                                    <Border Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><CheckBox x:Name="SelectVisibleCheckBox" Click="HeaderCheckBox_Click" IsThreeState="True" Style="{StaticResource SelectionCheckBoxStyle}" /></Border>
                                    <Border Grid.Column="1" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="ID" /></Border>
                                    <Border Grid.Column="2" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Proveidor" /></Border>
                                    <Border Grid.Column="3" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Producte" /></Border>
                                    <Border Grid.Column="4" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Quantitat" /></Border>
                                    <Border Grid.Column="5" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Data demanat" /></Border>
                                    <Border Grid.Column="6" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Data rebut" /></Border>
                                    <Border Grid.Column="7" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Caducitat" /></Border>
                                    <Border Grid.Column="8" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,1,1"><TextBlock FontWeight="SemiBold" Foreground="{StaticResource AppSecondaryTextBrush}" Text="Sincronitzacio" /></Border>
                                    <Border Grid.Column="9" Padding="12,10" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,0,0,1" />
                                </Grid>
                                <ListView x:Name="RecordsTable" Grid.Row="1" MinWidth="1230" Background="Transparent" ContextRequested="Records_ContextRequested" IsMultiSelectCheckBoxEnabled="False" ItemContainerStyle="{StaticResource TableItemStyle}" ItemTemplate="{StaticResource TableRowTemplate}" ItemsSource="{Binding FilteredRecords}" SelectionChanged="RecordsSelectionChanged" SelectionMode="Multiple" />
                            </Grid>
                        </ScrollViewer>
                        <GridView x:Name="RecordsGrid" Padding="14" Background="Transparent" ContextRequested="Records_ContextRequested" IsMultiSelectCheckBoxEnabled="False" ItemTemplate="{StaticResource GridItemTemplate}" ItemsSource="{Binding FilteredRecords}" SelectionChanged="RecordsSelectionChanged" SelectionMode="Multiple" Visibility="{Binding IsGridView, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Border Grid.Column="0" Background="#4D000000" IsHitTestVisible="True" Visibility="{Binding IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
        <Border Grid.Column="1" Width="520" Padding="24" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1,0,0,0" Visibility="{Binding IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Spacing="4"><TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}" Text="{Binding PanelTitle}" /><TextBlock Foreground="{StaticResource AppSecondaryTextBrush}" Text="{Binding PanelSubtitle}" /></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Visibility="{Binding IsEditingMultiple, Converter={StaticResource BoolToVisibilityConverter}}"><Button Width="34" Height="34" Padding="0" Click="PreviousEditButton_Click"><FontIcon Glyph="&#xE72B;" /></Button><Button Width="34" Height="34" Padding="0" Click="NextEditButton_Click"><FontIcon Glyph="&#xE72A;" /></Button></StackPanel></Grid>
                <ScrollViewer Grid.Row="1"><StackPanel Spacing="12">
                    <InfoBar IsClosable="False" IsIconVisible="True" IsOpen="{Binding HasValidationErrors}" Message="{Binding ValidationMessage}" Severity="Error" Title="Revisa el formulari" />
                    <ComboBox Header="Proveidor" DisplayMemberPath="DisplayText" ItemsSource="{Binding SupplierOptions}" PlaceholderText="Selecciona proveidor" SelectedValue="{Binding DraftIdProveidor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                    <ComboBox Header="Producte" DisplayMemberPath="DisplayText" ItemsSource="{Binding ProductOptions}" PlaceholderText="Selecciona producte" SelectedValue="{Binding DraftIdProducte, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" />
                    <NumberBox Header="Quantitat rebuda" Minimum="1" PlaceholderText="1" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" Value="{Binding DraftQuantitatRebudaValue, Mode=TwoWay}" />
                    <CalendarDatePicker Header="Data demanat" PlaceholderText="Opcional" Date="{Binding DraftDataDemanatDate, Mode=TwoWay}" />
                    <DatePicker Header="Data rebut" Date="{Binding DraftDataRebutDate, Mode=TwoWay}" />
                    <DatePicker Header="Data caducitat" Date="{Binding DraftDataCaducitatDate, Mode=TwoWay}" />
                </StackPanel></ScrollViewer>
                <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10"><Button Click="CancelPanelButton_Click" Content="Cancelar" /><Button Background="{StaticResource AppAccentBrush}" Click="SavePanelButton_Click" Content="Guardar" Foreground="White" /></StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
