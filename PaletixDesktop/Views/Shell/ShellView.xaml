<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PaletixDesktop.Views.Shell.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="ShellView_Loaded">

    <UserControl.Resources>
        <DataTemplate x:Key="CategoryTemplate">
            <Border
                MinHeight="50"
                Style="{StaticResource ShellCardBorderStyle}">
                <Grid>
                    <Border
                        Background="{StaticResource AppAccentBrush}"
                        CornerRadius="7"
                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <StackPanel
                        Margin="12,7"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <FontIcon
                            FontSize="15"
                            Foreground="{StaticResource AppPrimaryTextBrush}"
                            Glyph="{Binding Glyph}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppPrimaryTextBrush}"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SectionTemplate">
            <Border Padding="12" Style="{StaticResource ShellCardBorderStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.ColumnSpan="2"
                        Margin="-12"
                        Background="{StaticResource AppAccentBrush}"
                        CornerRadius="8"
                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <FontIcon
                        Margin="0,2,0,0"
                        VerticalAlignment="Top"
                        FontSize="17"
                        Foreground="{StaticResource AppPrimaryTextBrush}"
                        Glyph="{Binding Glyph}" />
                    <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppPrimaryTextBrush}"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource AppSecondaryTextBrush}"
                            Text="{Binding Subtitle}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CompactSectionTemplate">
            <Border
                MinHeight="54"
                Padding="0"
                Style="{StaticResource ShellCardBorderStyle}">
                <Grid>
                    <Border
                        Background="{StaticResource AppAccentBrush}"
                        CornerRadius="8"
                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="19"
                        Foreground="{StaticResource AppPrimaryTextBrush}"
                        Glyph="{Binding Glyph}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="NotificationTemplate">
            <Border
                Margin="0,0,0,8"
                Padding="10"
                Style="{StaticResource ShellCardBorderStyle}">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        Margin="0,2,0,0"
                        FontSize="15"
                        Foreground="{StaticResource AppSecondaryTextBrush}"
                        Glyph="&#xF2A3;" />
                    <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppPrimaryTextBrush}"
                            Text="{Binding Title}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource AppSecondaryTextBrush}"
                            Text="{Binding Message}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="2"
                        FontSize="12"
                        Foreground="{StaticResource AppSecondaryTextBrush}"
                        Text="{Binding TimeText}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PendingSyncTemplate">
            <Border
                Margin="0,0,0,8"
                Padding="10"
                Style="{StaticResource ShellCardBorderStyle}">
                <Grid ColumnSpacing="10" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="3">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppPrimaryTextBrush}"
                            Text="{Binding Summary}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource AppSecondaryTextBrush}"
                            Text="{Binding EntityLabel}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Spacing="3">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppPrimaryTextBrush}"
                            Text="{Binding OperationLabel}" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontSize="12"
                            Foreground="{StaticResource AppSecondaryTextBrush}"
                            Text="{Binding StatusLabel}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource AppSecondaryTextBrush}"
                        Text="{Binding UpdatedText}" />
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            MinWidth="34"
                            Padding="8,5"
                            Click="RetryPendingButton_Click"
                            Tag="{Binding}">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                        </Button>
                        <Button
                            MinWidth="34"
                            Padding="8,5"
                            Click="DiscardPendingButton_Click"
                            Tag="{Binding}">
                            <FontIcon FontSize="13" Glyph="&#xE711;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid
        x:Name="ShellRoot"
        Background="{StaticResource AppBackgroundBrush}"
        SizeChanged="ShellRoot_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="20,12,24,10" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource AppPrimaryTextBrush}"
                    Text="{Binding Shell.WindowTitle}" />
            </StackPanel>

            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    x:Name="NotificationsButton"
                    MinWidth="44"
                    Padding="10,7"
                    Click="NotificationsButton_Click">
                    <Grid>
                        <FontIcon
                            FontSize="15"
                            Glyph="&#xEA8F;" />
                        <Border
                            MinWidth="17"
                            Height="17"
                            Margin="12,-8,-9,0"
                            Padding="4,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="{StaticResource AppDangerBrush}"
                            CornerRadius="8"
                            Visibility="{Binding Notifications.HasUnread, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding Notifications.UnreadCountText}" />
                        </Border>
                    </Grid>
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel Width="360" Spacing="10">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Notificacions" />
                                <TextBlock
                                    Foreground="{StaticResource AppSecondaryTextBrush}"
                                    Text="No hi ha notificacions."
                                    Visibility="{Binding Notifications.HasNotifications, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                                <ScrollViewer MaxHeight="330">
                                    <ItemsControl
                                        ItemTemplate="{StaticResource NotificationTemplate}"
                                        ItemsSource="{Binding Notifications.Items}" />
                                </ScrollViewer>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button
                    x:Name="PendingSyncButton"
                    MinWidth="44"
                    Padding="10,7"
                    Click="PendingSyncButton_Click">
                    <Grid>
                        <FontIcon
                            FontSize="15"
                            Glyph="&#xE895;" />
                        <Border
                            MinWidth="17"
                            Height="17"
                            Margin="12,-8,-9,0"
                            Padding="4,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="{StaticResource AppDangerBrush}"
                            CornerRadius="8"
                            Visibility="{Binding Shell.HasPendingOperations, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding Shell.PendingOperationsText}" />
                        </Border>
                    </Grid>
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Grid Width="430" RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="Canvis pendents" />
                                        <TextBlock
                                            Foreground="{StaticResource AppSecondaryTextBrush}"
                                            Text="{Binding PendingSync.StatusText}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        Padding="9,6"
                                        Click="RefreshPendingButton_Click">
                                        <FontIcon FontSize="13" Glyph="&#xE72C;" />
                                    </Button>
                                    <Button
                                        Grid.Column="2"
                                        Padding="10,6"
                                        Click="RetryAllPendingButton_Click"
                                        Content="Reintentar tot" />
                                </Grid>
                                <TextBlock
                                    Grid.Row="1"
                                    Foreground="{StaticResource AppSecondaryTextBrush}"
                                    Text="No hi ha operacions pendents."
                                    Visibility="{Binding PendingSync.HasItems, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                                <ScrollViewer Grid.Row="2" MaxHeight="430">
                                    <ItemsControl
                                        ItemTemplate="{StaticResource PendingSyncTemplate}"
                                        ItemsSource="{Binding PendingSync.Items}" />
                                </ScrollViewer>
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Border
                    Padding="10,7"
                    Style="{StaticResource ShellCardBorderStyle}"
                    Visibility="{Binding ImportJob.IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <TextBlock
                            MaxWidth="180"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource AppPrimaryTextBrush}"
                            Text="{Binding ImportJob.StatusText}"
                            TextTrimming="CharacterEllipsis" />
                        <ProgressBar
                            Width="130"
                            VerticalAlignment="Center"
                            IsIndeterminate="True"
                            ShowError="False"
                            ShowPaused="{Binding ImportJob.IsPaused}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{StaticResource AppSecondaryTextBrush}"
                            Text="{Binding ImportJob.ProgressText}" />
                        <Button
                            MinWidth="34"
                            Padding="8,5"
                            Click="ToggleImportPauseButton_Click"
                            ToolTipService.ToolTip="{Binding ImportJob.PauseResumeTooltip}">
                            <FontIcon
                                FontSize="13"
                                Glyph="{Binding ImportJob.PauseResumeGlyph}" />
                        </Button>
                        <Button
                            MinWidth="34"
                            Padding="8,5"
                            Click="CancelImportButton_Click"
                            ToolTipService.ToolTip="Cancel.lar importacio">
                            <FontIcon
                                FontSize="13"
                                Glyph="&#xE711;" />
                        </Button>
                    </StackPanel>
                </Border>
                <Border
                    Padding="13,8"
                    Background="{Binding Shell.SyncStateBackground}"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            FontSize="13"
                            Foreground="White"
                            Glyph="&#xE774;" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding Shell.SyncStateText}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <ListView
                x:Name="CategoryList"
                Grid.Column="1"
                MaxHeight="66"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Transparent"
                IsItemClickEnabled="False"
                ItemContainerStyle="{StaticResource ShellTopTabItemStyle}"
                ItemTemplate="{StaticResource CategoryTemplate}"
                ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                SelectionChanged="CategoryList_SelectionChanged"
                SelectionMode="Single">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>
        </Grid>

        <CommandBar
            x:Name="RibbonBar"
            Grid.Row="1"
            Padding="18,0"
            Background="{StaticResource AppSurfaceBrush}"
            DefaultLabelPosition="Right" />

        <InfoBar
            Grid.Row="2"
            Margin="18,10,18,0"
            IsClosable="False"
            IsIconVisible="True"
            IsOpen="{Binding Shell.HasStatusAlert}"
            Message="{Binding Shell.StatusAlertMessage}"
            Severity="{Binding Shell.StatusAlertSeverity}"
            Title="{Binding Shell.StatusAlertTitle}">
            <InfoBar.ActionButton>
                <Button
                    Click="RetryAllPendingButton_Click"
                    Content="Sincronitzar" />
            </InfoBar.ActionButton>
        </InfoBar>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{x:Bind ViewModel.SidePanelWidth, Mode=OneWay}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid
                Padding="18,16,14,16"
                Background="{StaticResource AppSurfaceAltBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Margin="0,0,0,14"
                    Spacing="4"
                    Visibility="{Binding IsCompact, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AppPrimaryTextBrush}"
                        Text="{Binding ActiveCategoryTitle}" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource AppSecondaryTextBrush}"
                        Text="{Binding ActiveCategorySubtitle}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <ListView
                    x:Name="SectionsList"
                    Grid.Row="1"
                    Background="Transparent"
                    ItemContainerStyle="{StaticResource ShellSectionItemStyle}"
                    ItemTemplate="{StaticResource SectionTemplate}"
                    ItemsSource="{x:Bind ViewModel.ActiveSections, Mode=OneWay}"
                    SelectionChanged="SectionsList_SelectionChanged"
                    SelectionMode="Single"
                    Visibility="{Binding IsCompact, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />

                <ListView
                    x:Name="CompactSectionsList"
                    Grid.Row="1"
                    Background="Transparent"
                    ItemContainerStyle="{StaticResource ShellSectionItemStyle}"
                    ItemTemplate="{StaticResource CompactSectionTemplate}"
                    ItemsSource="{x:Bind ViewModel.ActiveSections, Mode=OneWay}"
                    SelectionChanged="CompactSectionsList_SelectionChanged"
                    SelectionMode="Single"
                    Visibility="{Binding IsCompact, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    MinHeight="76"
                    Padding="12"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Visibility="{Binding IsCompact, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="42"
                            Height="42"
                            VerticalAlignment="Center"
                            Background="{StaticResource AppAccentBrush}"
                            CornerRadius="21">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding Shell.CurrentUser.Initials}" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="3">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{StaticResource AppPrimaryTextBrush}"
                                Text="{Binding Shell.UserDisplayName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{StaticResource AppSecondaryTextBrush}"
                                Text="{Binding Shell.UserRoleLine}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{StaticResource AppSecondaryTextBrush}"
                                Text="{Binding Shell.UserProgressLine}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                    <Button.Flyout>
                        <Flyout Placement="TopEdgeAlignedLeft">
                            <Grid Width="320" RowSpacing="18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="68"
                                        Height="68"
                                        Background="{StaticResource AppAccentBrush}"
                                        CornerRadius="34">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding Shell.CurrentUser.Initials}" />
                                    </Border>
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                        <TextBlock
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource AppPrimaryTextBrush}"
                                            Text="{Binding Shell.UserDisplayName}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Foreground="{StaticResource AppSecondaryTextBrush}"
                                            Text="{Binding Shell.UserRoleLine}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Foreground="{StaticResource AppSecondaryTextBrush}"
                                            Text="{Binding Shell.UserProgressLine}" />
                                    </StackPanel>
                                </Grid>

                                <InfoBar
                                    Grid.Row="1"
                                    IsClosable="False"
                                    IsIconVisible="True"
                                    IsOpen="{Binding Shell.HasStatusAlert}"
                                    Message="{Binding Shell.StatusAlertMessage}"
                                    Severity="{Binding Shell.StatusAlertSeverity}"
                                    Title="{Binding Shell.StatusAlertTitle}" />

                                <Button
                                    Grid.Row="2"
                                    MinHeight="40"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Click="LogoutButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xF3B1;" />
                                        <TextBlock Text="Tancar sessio" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <ContentControl
                x:Name="ContentHost"
                Grid.Column="1" />
        </Grid>
    </Grid>
</UserControl>
